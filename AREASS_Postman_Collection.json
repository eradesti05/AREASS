        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const data = pm.response.json();",
                  "    pm.environment.set('token', data.token);",
                  "    pm.environment.set('userId', data.user._id);",
                  "    pm.environment.set('userRole', data.user.role);",
                  "    pm.environment.set('userName', data.user.nama);",
                  "    console.log('✅ Login berhasil - Token: ' + data.token.substring(0, 20) + '...');",
                  "    console.log('Role: ' + data.user.role);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"12345@student.example.com\",\n  \"password\": \"Password123!\",\n  \"userType\": \"mahasiswa\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login dan dapatkan JWT token. Token berlaku 7 hari"
          },
          "response": []
        },
