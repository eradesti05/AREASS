      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Register Mahasiswa",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    pm.environment.set('token', pm.response.json().token);",
                  "    pm.environment.set('userId', pm.response.json().user._id);",
                  "    console.log('✅ Token berhasil disimpan');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nama\": \"Budi Santoso\",\n  \"email\": \"12345@student.example.com\",\n  \"password\": \"Password123!\",\n  \"userType\": \"mahasiswa\",\n  \"prodi\": \"Teknik Informatika\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Register akun baru untuk mahasiswa. NIM auto-extract dari email (angka di depan @)"
          },
          "response": []
        },
